{
  "entities": {
    "Quote": {
      "title": "Quote",
      "description": "A saved quote/presupuesto for a stand.",
      "type": "object",
      "properties": {
        "cliente": {
          "type": "string",
          "description": "Name of the client."
        },
        "evento": {
          "type": "string",
          "description": "Name of the event."
        },
        "fechaInicio": {
          "type": "string",
          "description": "Start date of the event."
        },
        "fechaFin": {
          "type": "string",
          "description": "End date of the event."
        },
        "selectedCity": {
          "type": "string",
          "description": "Selected city for the stand."
        },
        "selectedSize": {
          "type": "string",
          "description": "Selected size of the stand in m2."
        },
        "lote": {
          "type": "string",
          "description": "Lot number."
        },
        "standAncho": {
          "type": "string",
          "description": "Width of the stand."
        },
        "standProfundo": {
          "type": "string",
          "description": "Depth of the stand."
        },
        "cuit": {
          "type": "string",
          "description": "CUIT of the client."
        },
        "lugarArmado": {
          "type": "string",
          "description": "Assembly location."
        },
        "extrasQty": {
          "type": "object",
          "description": "Map of extra item IDs to their quantities."
        },
        "customExtras": {
          "type": "array",
          "description": "List of custom extra items.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "ipcMonth": {
          "type": "string",
          "description": "Month of the IPC used."
        },
        "ipcValue": {
          "type": "number",
          "description": "Value of the IPC used."
        },
        "basePrice": {
          "type": "number",
          "description": "Calculated base price."
        },
        "freightPrice": {
          "type": "number",
          "description": "Calculated freight price."
        },
        "extrasTotal": {
          "type": "number",
          "description": "Calculated extras total."
        },
        "grandTotal": {
          "type": "number",
          "description": "Calculated grand total."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the quote was created."
        }
      },
      "required": ["cliente", "evento", "selectedCity", "selectedSize", "extrasQty", "ipcMonth", "ipcValue", "basePrice", "freightPrice", "extrasTotal", "grandTotal"]
    }
  },
  "firestore": {
    "/quotes/{quoteId}": {
      "schema": {
        "$ref": "#/entities/Quote"
      },
      "description": "Stores all the quotes created by users."
    }
  }
}
