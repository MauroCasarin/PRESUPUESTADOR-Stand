rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quotes
    // Document ID: [auto-generated]
    // Fields:
    //   - cliente: string (required) - Name of the client.
    //   - cuit: string (optional) - CUIT of the client.
    //   - evento: string (required) - Name of the event.
    //   - fechaInicio: string (optional) - Start date of the event.
    //   - fechaFin: string (optional) - End date of the event.
    //   - selectedCity: string (required) - Selected city for the stand.
    //   - selectedSize: string (required) - Selected size of the stand in m2.
    //   - lote: string (optional) - Lot number.
    //   - standAncho: string (optional) - Width of the stand.
    //   - standProfundo: string (optional) - Depth of the stand.
    //   - lugarArmado: string (optional) - Assembly location.
    //   - extrasQty: map (required) - Map of extra item IDs to their quantities.
    //   - graficasList: list (optional) - List of graphics dimensions.
    //   - customExtras: list (optional) - List of custom extra items.
    //   - ipcMonth: string (required) - Month of the IPC used.
    //   - ipcValue: number (required) - Value of the IPC used.
    //   - basePrice: number (required) - Calculated base price.
    //   - freightPrice: number (required) - Calculated freight price.
    //   - extrasTotal: number (required) - Calculated extras total.
    //   - clientPaymentDays: number (optional) - Client payment days.
    //   - financialSurchargePercent: number (optional) - Financial surcharge percentage.
    //   - subtotal: number (optional) - Subtotal amount.
    //   - financialSurchargeAmount: number (optional) - Financial surcharge amount.
    //   - grandTotal: number (required) - Calculated grand total.
    //   - createdAt: timestamp (optional) - When the quote was created.
    //
    // Collection: clients
    // Document ID: [auto-generated]
    // Fields:
    //   - name: string (required) - Name of the client.
    //   - cuit: string (optional) - CUIT of the client.
    //   - paymentDays: number (optional) - Default payment days.
    //   - createdAt: timestamp (optional) - When the client was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mauro.j.casarin@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidQuote() {
      let d = request.resource.data;
      return d.keys().hasAll(['cliente', 'evento', 'selectedCity', 'selectedSize', 'ipcMonth', 'ipcValue', 'basePrice', 'freightPrice', 'extrasTotal', 'grandTotal']) &&
             d.cliente is string && d.cliente.size() > 0 && d.cliente.size() <= 200 &&
             d.evento is string && d.evento.size() > 0 && d.evento.size() <= 200 &&
             d.selectedCity is string && d.selectedCity.size() <= 100 &&
             d.selectedSize is string && d.selectedSize.size() <= 10 &&
             d.ipcMonth is string && d.ipcMonth.size() <= 50 &&
             d.ipcValue is number &&
             d.basePrice is number &&
             d.freightPrice is number &&
             d.extrasTotal is number &&
             d.grandTotal is number;
    }

    function isValidClient() {
      let d = request.resource.data;
      return d.keys().hasAll(['name']) &&
             d.name is string && d.name.size() > 0 && d.name.size() <= 200 &&
             (!('cuit' in d) || (d.cuit is string && d.cuit.size() <= 20)) &&
             (!('paymentDays' in d) || (d.paymentDays is number && d.paymentDays >= 0));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /quotes/{quoteId} {
      allow read: if true; // Allow public read for now as per app usage
      allow create, update: if isValidQuote();
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if true; // Allow public read for now
      allow create, update: if isValidClient();
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
