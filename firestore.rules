rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quotes
    // Document ID: [auto-generated]
    // Fields:
    //   - cliente: string (required) - Name of the client.
    //   - evento: string (required) - Name of the event.
    //   - selectedCity: string (required) - Selected city for the stand.
    //   - selectedSize: string (required) - Selected size of the stand in m2.
    //   - extrasQty: map (required) - Map of extra item IDs to their quantities.
    //   - ipcMonth: string (required) - Month of the IPC used.
    //   - ipcValue: number (required) - Value of the IPC used.
    //   - basePrice: number (required) - Calculated base price.
    //   - freightPrice: number (required) - Calculated freight price.
    //   - extrasTotal: number (required) - Calculated extras total.
    //   - grandTotal: number (required) - Calculated grand total.
    //   - createdAt: timestamp (required) - When the quote was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidQuote() {
      return hasRequiredFields(['cliente', 'evento', 'selectedCity', 'selectedSize', 'extrasQty', 'ipcMonth', 'ipcValue', 'basePrice', 'freightPrice', 'extrasTotal', 'grandTotal', 'createdAt']) &&
             hasOnlyAllowedFields(['cliente', 'evento', 'selectedCity', 'selectedSize', 'extrasQty', 'ipcMonth', 'ipcValue', 'basePrice', 'freightPrice', 'extrasTotal', 'grandTotal', 'createdAt']) &&
             validStringLength('cliente', 1, 200) &&
             validStringLength('evento', 1, 200) &&
             validStringLength('selectedCity', 1, 100) &&
             validStringLength('selectedSize', 1, 10) &&
             request.resource.data.extrasQty is map &&
             validStringLength('ipcMonth', 1, 50) &&
             isPositive('ipcValue') &&
             isPositive('basePrice') &&
             isPositive('freightPrice') &&
             isPositive('extrasTotal') &&
             isPositive('grandTotal') &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /quotes/{quoteId} {
      // Allow public read and write as requested
      allow read: if true;
      allow create: if isValidQuote();
      allow update: if isValidQuote() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if true;
    }
  }
}
