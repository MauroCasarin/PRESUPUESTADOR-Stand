rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quotes
    // Document ID: [auto-generated]
    // Fields:
    //   - cliente: string (required) - Name of the client.
    //   - evento: string (required) - Name of the event.
    //   - fechaInicio: string (optional) - Start date of the event.
    //   - fechaFin: string (optional) - End date of the event.
    //   - selectedCity: string (required) - Selected city for the stand.
    //   - selectedSize: string (required) - Selected size of the stand in m2.
    //   - extrasQty: map (required) - Map of extra item IDs to their quantities.
    //   - ipcMonth: string (required) - Month of the IPC used.
    //   - ipcValue: number (required) - Value of the IPC used.
    //   - basePrice: number (required) - Calculated base price.
    //   - freightPrice: number (required) - Calculated freight price.
    //   - extrasTotal: number (required) - Calculated extras total.
    //   - grandTotal: number (required) - Calculated grand total.
    //   - createdAt: timestamp (optional) - When the quote was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidQuote() {
      let d = request.resource.data;
      return d.keys().hasAll(['cliente', 'evento', 'selectedCity', 'selectedSize', 'ipcMonth', 'ipcValue', 'basePrice', 'freightPrice', 'extrasTotal', 'grandTotal']) &&
             d.cliente is string && d.cliente.size() > 0 && d.cliente.size() <= 200 &&
             d.evento is string && d.evento.size() > 0 && d.evento.size() <= 200 &&
             d.selectedCity is string && d.selectedCity.size() <= 100 &&
             d.selectedSize is string && d.selectedSize.size() <= 10 &&
             d.ipcMonth is string && d.ipcMonth.size() <= 50 &&
             d.ipcValue is number &&
             d.basePrice is number &&
             d.freightPrice is number &&
             d.extrasTotal is number &&
             d.grandTotal is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /quotes/{quoteId} {
      allow read, write: if true;
    }
    match /clients/{clientId} {
      allow read, write: if true;
    }
  }
}
