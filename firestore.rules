rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quotes
    // Document ID: [auto-generated]
    // Fields:
    //   - userId: string (required) - The UID of the user who created the quote.
    //   - cliente: string (required) - Name of the client.
    //   - evento: string (required) - Name of the event.
    //   - selectedCity: string (required) - Selected city for the stand.
    //   - selectedSize: string (required) - Selected size of the stand in m2.
    //   - extrasQty: map (required) - Map of extra item IDs to their quantities.
    //   - ipcMonth: string (required) - Month of the IPC used.
    //   - ipcValue: number (required) - Value of the IPC used.
    //   - basePrice: number (required) - Calculated base price.
    //   - freightPrice: number (required) - Calculated freight price.
    //   - extrasTotal: number (required) - Calculated extras total.
    //   - grandTotal: number (required) - Calculated grand total.
    //   - createdAt: timestamp (required) - When the quote was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidQuote() {
      return hasRequiredFields(['userId', 'cliente', 'evento', 'selectedCity', 'selectedSize', 'extrasQty', 'ipcMonth', 'ipcValue', 'basePrice', 'freightPrice', 'extrasTotal', 'grandTotal', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'cliente', 'evento', 'selectedCity', 'selectedSize', 'extrasQty', 'ipcMonth', 'ipcValue', 'basePrice', 'freightPrice', 'extrasTotal', 'grandTotal', 'createdAt']) &&
             validStringLength('userId', 1, 100) &&
             validStringLength('cliente', 1, 200) &&
             validStringLength('evento', 1, 200) &&
             validStringLength('selectedCity', 1, 100) &&
             validStringLength('selectedSize', 1, 10) &&
             request.resource.data.extrasQty is map &&
             validStringLength('ipcMonth', 1, 50) &&
             isPositive('ipcValue') &&
             isPositive('basePrice') &&
             isPositive('freightPrice') &&
             isPositive('extrasTotal') &&
             isPositive('grandTotal') &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /quotes/{quoteId} {
      // Only the owner can read their quotes
      allow read: if isDocOwner();
      
      // Only authenticated users can create quotes, and they must be the owner
      allow create: if isAuthenticated() && 
                    isValidQuote() && 
                    uidUnchanged();
                    
      // Only the owner can update their quotes, and they cannot change the owner or createdAt
      allow update: if isDocOwner() && 
                    isValidQuote() && 
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt']);
                    
      // Only the owner can delete their quotes
      allow delete: if isDocOwner();
    }
  }
}
